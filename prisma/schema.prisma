// prisma/schema.prisma
generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUM ها (دقیقاً برابر با enumهای Mongoose)
// ============================================

enum AdType {
  EmployerAd
  JobSeekerAd
  SellerAd
  DigitalAd
}

enum MarkType {
  favorite
  suspicious
  seen
}

enum PersonType {
  self
  other
}

enum AdStatus {
  pending
  approved
  rejected
  expired   // اضافه شده برای مدیریت آگهی‌های منقضی شده
}

enum PaymentMethod {
  Subscription
  Wallet
  Bank_card
}

enum Gender {
  male
  female
}

enum UserRole {
  USER       @map("0")
  EMPLOYER   @map("1")
  JOB_SEEKER @map("3")
  SELLER     @map("5")
}

enum ReportType {
  employerAd
  jobSeekerAd
  sellerAd
  DigitalAd
  chat
}

enum ReportStatus {
  pending
  reviewed
  rejected
}

enum ReportReasonType {
  general
  employerAd
  jobSeekerAd
  sellerAd
  DigitalAd
  chat_employerAd
  chat_jobSeekerAd
  chat_sellerAd
  chat_DigitalAd
}

enum TicketStatus {
  open
  in_progress
  closed
}

enum TestSessionStatus {
  in_progress
  completed
}

enum ScoringMethod {
  weighted_level
  trait_accumulation
  forced_choice_mbti
  likert_sum
  mbti_polar
}

enum TimeUnit {
  minute
  hour
  day
  month
  year
}

enum AdminRole {
  admin
  super_admin
}

// ============================================
// مدل‌ها (دقیقاً با همان نام و فیلدها)
// ============================================

model User {
  id                       String    @id @default(uuid())
  name                     String
  lastName                 String
  username                 String?   @unique
  nationalCode             String    @unique
  phone                    String    @unique
  password                 String
  birthDate                String
  gender                   Gender
  province                 String
  city                     String
  acceptTerms              Boolean   @default(false)
  role                     UserRole  @default(USER)
  joinedAt                 String
  email                    String?   @unique
  email_confirmed          Boolean   @default(false)
  tempEmail                String?   @unique
  emailVerificationCode    String?
  emailVerificationExpires DateTime?
  phone_confirmed          Boolean   @default(false)
  email_log_num            Int       @default(0)
  phone_log_num            Int       @default(0)
  referralCode             String    @default("")
  online                   Boolean   @default(false)
  lastSeen                 DateTime  @default(now())
  sessions                 Session[] @relation("UserSessions")
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  // روابط
  adMarks           AdMark[]
  adViews           AdView[]
  chatFrom          Chat[]         @relation("ChatFrom")
  chatTo            Chat[]         @relation("ChatTo")
  digitalAds        DigitalAd[]
  employerAds       EmployerAd[]
  jobSeekerAds      JobSeekerAd[]
  sellerAds         SellerAd[]
  notifications     Notification[] @relation("NotificationUser")
  sentNotifications Notification[] @relation("NotificationFromUser")
  reports           Report[]       @relation("Reporter")
  reportReasons     ReportReason[] @relation("ReasonCreator")
  resumes           Resume[]
  tickets           Ticket[]
  ticketReplies     TicketReply[]
  toolUsageLogs     ToolUsageLog[]
  userProfiles      UserProfile[]
  recentViews       RecentView[]
  testSessions      TestSession[]
  // ===== روابط جدید برای سیستم پیشنهادات ویژه =====
  suggestionViews        SuggestionView[]          // هر کاربر چندین نمایش پیشنهاد دارد
  suggestionPreference   UserSuggestionPreference? // هر کاربر یک تنظیمات پیشنهاد (One-to-One)
  suggestionDailyLimits  SuggestionDailyLimit[]    // هر کاربر چندین محدودیت روزانه دارد
  cachedSuggestions      CachedUserSuggestions?    // هر کاربر یک کش از پیشنهادات خود دارد (One-to-One)
  wallet            Wallet?
}

model UserProfile {
  id             String   @id @default(uuid())
  user           String   @unique
  profileImage   String   @default("")
  address        String   @default("")
  educationLevel String?
  aboutMe        String?
  interests      String[]
  skills         String[]
  resumeFile     String?
  portfolioFiles String[]
  documents      Json[] // [{title: String, file: String}]
  completed      Boolean  @default(false)
  updatedAt      DateTime @default(now())
  wallet         Wallet?  @relation(fields: [walletId], references: [id])

  userRelation User    @relation(fields: [user], references: [id])
  walletId     String?
}

model Province {
  id     String   @id @default(uuid())
  name   String
  cities String[]
}

model AdCategory {
  id     String  @id @default(uuid())
  name   String
  parent String?

  parentRelation AdCategory?            @relation("AdCategoryParent", fields: [parent], references: [id])
  children       AdCategory[]           @relation("AdCategoryParent")
  attributes     AdCategoryAttributes[]
}

model AdCategoryAttributes {
  id           String @id @default(uuid())
  adCategoryId String @unique
  categoryId   Int
  attributes   Json   @default("{}")

  adCategory AdCategory @relation(fields: [adCategoryId], references: [id])
}

model AdMark {
  id        String   @id @default(uuid())
  userId    String
  adId      String
  adType    AdType
  type      MarkType @default(favorite)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, adId, adType])
}

model AdView {
  id       String   @id @default(uuid())
  adId     String
  adType   AdType
  ownerId  String
  viewedAt DateTime @default(now())

  owner User @relation(fields: [ownerId], references: [id])

  @@index([ownerId, viewedAt])
}

model Chat {
  id             String   @id @default(uuid())
  from           String
  to             String
  adId           String
  adType         AdType
  conversationId String
  content        String
  type           String?  @default("text")
  read           Boolean  @default(false)
  createdAt      DateTime @default(now())

  fromUser     User         @relation("ChatFrom", fields: [from], references: [id])
  toUser       User         @relation("ChatTo", fields: [to], references: [id])
  conversation Conversation @relation(fields: [conversationId], references: [id])

  @@index([conversationId])
}

model Conversation {
  id           String   @id @default(uuid())
  participants String[]
  adId         String
  adType       String
  lastMessage  String?
  updatedAt    DateTime @default(now())

  chats Chat[]
}

model DigitalAd {
  id                  String        @id @default(uuid())
  owner               String
  images              Json[] // [{url: String, isMain: Boolean}]
  title               String
  description         String
  digitalTotalDesc    String?
  projectNames        String[]
  projectDescriptions String[]
  minBudget           String?
  maxBudget           String?
  requiredSkills      Json[] // [{name: String}]
  person              PersonType    @default(self)
  remote              Boolean       @default(false)
  thursdayHalf        Boolean       @default(false)
  verifyCode          String?
  paymentMethod       PaymentMethod @default(Bank_card)
  adStatus            AdStatus      @default(pending)
  requestType         String? // "requester" | "provider"
  durationUnit        TimeUnit?     @default(day)
  durationAmount      String?
  createdAt           DateTime      @default(now())

  // فیلدهای جدید برای مدیریت انقضای آگهی تایید شده
  approvedAt          DateTime?     // زمان تایید آگهی
  expiresAt           DateTime?     // یک ماه بعد از approvedAt

  ownerRelation User @relation(fields: [owner], references: [id])
}

model EmailOTP {
  id        String   @id @default(uuid())
  email     String
  code      String
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model EmployerAd {
  id                 String        @id @default(uuid())
  owner              String
  images             Json[] // [{url: String, isMain: Boolean}]
  name               String
  title              String
  categories         Json[] // [{name: String, subCategories: [String]}]
  state              String?
  city               String?
  cooperationType    String?
  gender             String?
  militaryStatus     String?       @default("None")
  experience         String?
  paymentMethod      String?
  isRemote           Boolean       @default(false)
  thursdayUntilNoon  Boolean       @default(false)
  startTime          String?
  endTime            String?
  minSalary          String?
  maxSalary          String?
  companyName        String?
  companyType        String?
  benefits           String?
  insurance          String?
  education          String?
  companyDescription String?
  jobDetails         Json[] // [{title: String, description: String}]
  rating             Json          @default("{\"average\":0,\"count\":0}")
  person             PersonType    @default(self)
  isVerified         Boolean       @default(false)
  enableChat         Boolean       @default(false)
  enablePhone        Boolean       @default(false)
  adPaymentMethod    PaymentMethod @default(Bank_card)
  adStatus           AdStatus      @default(pending)
  createdAt          DateTime      @default(now())

  // فیلدهای جدید برای مدیریت انقضای آگهی تایید شده
  approvedAt          DateTime?     // زمان تایید آگهی
  expiresAt           DateTime?     // یک ماه بعد از approvedAt

  ownerRelation User @relation(fields: [owner], references: [id])
}

model JobCategory {
  id     String  @id @default(uuid())
  name   String
  parent String?

  parentRelation JobCategory?  @relation("JobCategoryParent", fields: [parent], references: [id])
  children       JobCategory[] @relation("JobCategoryParent")
}

model JobSeekerAd {
  id                 String        @id @default(uuid())
  owner              String
  images             Json[] // [{url: String, isMain: Boolean}]
  name               String
  age                String?
  gender             String?
  maritalStatus      String?
  militaryStatus     String?
  phoneNumber        String
  state              String?
  city               String?
  category           String
  resumeFile         String?
  workSampleFile     String?
  education          String?
  skills             String[]
  suggestedSalaryIRT String?
  aboutMe            String?
  instagram          String?
  linkedIn           String?
  gitHub             String?
  careerHistory      Json[] // [{title: String, description: String}]
  rating             Json          @default("{\"average\":0,\"count\":0}")
  person             PersonType    @default(self)
  isVerified         Boolean       @default(false)
  enableChat         Boolean       @default(true)
  enablePhone        Boolean       @default(false)
  paymentMethod      PaymentMethod @default(Bank_card)
  adStatus           AdStatus      @default(pending)
  userDesc           String        @default("")
  createdAt          DateTime      @default(now())

  // فیلدهای جدید برای مدیریت انقضای آگهی تایید شده
  approvedAt          DateTime?     // زمان تایید آگهی
  expiresAt           DateTime?     // یک ماه بعد از approvedAt

  ownerRelation User @relation(fields: [owner], references: [id])
}

model Notification {
  id         String   @id @default(uuid())
  userId     String
  fromUserId String
  message    String
  adId       String
  adType     AdType
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  user     User @relation("NotificationUser", fields: [userId], references: [id])
  fromUser User @relation("NotificationFromUser", fields: [fromUserId], references: [id])
}

model Otp {
  id        String   @id @default(uuid())
  phone     String
  code      String
  purpose   String   @default("default")
  createdAt DateTime @default(now())

  @@index([purpose])
  @@index([createdAt])
}

model Question {
  id              String   @id @default(uuid())
  typeId          String
  subject         String
  level           String
  questionText    String
  options         Json[] // [{text: String, value: Int, isCorrect: Boolean, traitPoints: Json}]
  dimension       String?
  isReverseScored Boolean  @default(false)
  explanation     String?
  createdAt       DateTime @default(now())
  metadata        Json?

  testType TestType @relation(fields: [typeId], references: [id])
}

model RecentView {
  id       String   @id @default(uuid())
  user     String
  ad       String
  adType   AdType
  viewedAt DateTime @default(now())

  userRelation User @relation(fields: [user], references: [id])

  @@unique([user, ad])
  @@index([user, viewedAt])
  @@index([user, adType, viewedAt])
}

model Report {
  id             String       @id @default(uuid())
  reporterUserId String
  targetId       String
  reportType     ReportType
  reason         String
  description    String
  status         ReportStatus @default(pending)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  reporter User @relation("Reporter", fields: [reporterUserId], references: [id])
}

model ReportReason {
  id          String           @id @default(uuid())
  type        ReportReasonType @default(general)
  key         String
  label       String
  description String
  order       Int              @default(0)
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  createdBy   User   @relation("ReasonCreator", fields: [createdById], references: [id])
  createdById String

  @@unique([type, key])
  @@index([type, order])
}

model Resume {
  id                   String   @id @default(uuid())
  userId               String
  updateCount          Int      @default(0)
  fullName             String?
  phoneNumber          String?
  birthDate            String?
  gender               String?
  maritalStatus        String?
  address              String?
  expectedSalary       String?
  cooperationType      String?
  hasInsuranceHistory  Boolean  @default(false)
  willingToGoOnMission Boolean  @default(false)
  skills               String[]
  education            Json[] // [{major: String, university: String, gpa: String}]
  workExperience       Json[] // [{jobTitle: String, companyName: String, duration: String}]
  certificates         Json[] // [{title: String, provider: String, date: String}]
  fileUrl              String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model SellerAd {
  id            String        @id @default(uuid())
  title         String
  description   String        @default("")
  category      String
  state         String
  city          String
  application   String?
  status        String?
  images        Json[] // [{url: String, isMain: Boolean}]
  priceIRT      Int           @default(0)
  isFixedPrice  Boolean       @default(false)
  isNegotiable  Boolean       @default(false)
  hasWarranty   Boolean       @default(false)
  isShippable   Boolean       @default(false)
  extraFeatures Json          @default("{}")
  rating        Json          @default("{\"average\":0,\"count\":0}")
  person        PersonType    @default(self)
  isVerified    Boolean       @default(false)
  enableChat    Boolean       @default(false)
  enablePhone   Boolean       @default(false)
  paymentMethod PaymentMethod @default(Bank_card)
  adStatus      AdStatus      @default(pending)
  createdAt     DateTime      @default(now())
  owner         String

  // فیلدهای جدید برای مدیریت انقضای آگهی تایید شده
  approvedAt          DateTime?     // زمان تایید آگهی
  expiresAt           DateTime?     // یک ماه بعد از approvedAt

  ownerRelation User @relation(fields: [owner], references: [id])
}

model Session {
  id           String   @id @default(uuid())
  user         String
  deviceInfo   Json // {userAgent, ip, deviceType, browser, os}
  refreshToken String
  isActive     Boolean  @default(true)
  lastActiveAt DateTime @default(now())
  isRead       Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userRelation User @relation("UserSessions", fields: [user], references: [id])
}

model TestCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  icon        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  testTypes TestType[]
}

model TestType {
  id            String        @id @default(uuid())
  categoryId    String
  name          String
  tags          String[]
  description   String?
  scoringMethod ScoringMethod
  dimensions    String[]
  blueprint     Json // {structure: Json, levelWeights: Map, totalQuestions: Int, timeLimit: Int}
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  category     TestCategory  @relation(fields: [categoryId], references: [id])
  questions    Question[]
  testSessions TestSession[]
}

model TestSession {
  id             String            @id @default(uuid())
  userId         String
  typeId         String
  questions      Json[] // [{questionId, userAnswer, isCorrect, pointsEarned, dimension, subject, level}]
  score          Int?
  assignedLevel  String?
  levelResults   Json? // Map
  status         TestSessionStatus @default(in_progress)
  startedAt      DateTime          @default(now())
  finishedAt     DateTime?
  quickResult    Json?
  detailedResult Json?

  testType TestType @relation(fields: [typeId], references: [id])
  user     User     @relation(fields: [userId], references: [id])
}

model Ticket {
  id            String       @id @default(uuid())
  user          String
  email         String
  phone         String
  title         String
  description   String
  status        TicketStatus @default(open)
  statusHistory Json[] // [{status: TicketStatus, changedAt: String}]
  createdAt     String
  updatedAt     String

  userRelation User          @relation(fields: [user], references: [id])
  replies      TicketReply[]
}

model TicketReply {
  id        String   @id @default(uuid())
  ticketId  String
  userId    String
  message   String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id])
  user   User   @relation(fields: [userId], references: [id])
}

model ToolUsageLog {
  id           String   @id @default(uuid())
  userId       String
  toolName     String // "convert-image", "merge-pdf", ...
  status       String // "success" | "failed"
  errorMessage String?
  metadata     Json? // {inputSize, outputSize, inputFormat, outputFormat}
  durationMs   Int?
  ip           String?
  userAgent    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@index([toolName, status, createdAt])
  @@index([userId, createdAt])
}

model Admin {
  id        String    @id @default(uuid())
  role      AdminRole
  firstname String?
  lastname  String?
  phone     String    @unique
  password  String
  verified  Boolean   @default(false)
  createdAt DateTime  @default(now())
}

// ============================================
// جداول مربوط به سیستم پیشنهادات ویژه (Special Suggestions)
// ============================================

// ------------------------------------------------------------
// 1. جدول SuggestionView
// هدف: ثبت هر بار نمایش یک آگهی در بخش پیشنهادات به کاربر
// کاربرد: شمارش تعداد دفعات استفاده از پیشنهادات توسط هر کاربر
// ------------------------------------------------------------
model SuggestionView {
  id        String   @id @default(uuid())
  userId    String
  adId      String   // شناسه آگهی (بدون توجه به نوع)
  adType    AdType   // نوع آگهی (EmployerAd, JobSeekerAd, SellerAd, DigitalAd)
  viewedAt  DateTime @default(now())

  // ارتباط با کاربر
  user      User     @relation(fields: [userId], references: [id])

  // ایندکس‌ها برای جستجوی سریع
  @@unique([userId, adId, adType])        // جلوگیری از ثبت تکراری در یک نمایش (اختیاری)
  @@index([userId, viewedAt])             // برای شمارش تعداد نمایش‌های یک کاربر
  @@index([adId, adType])                 // برای تحلیل عملکرد آگهی‌ها
}

// ------------------------------------------------------------
// 2. جدول UserSuggestionPreference
// هدف: ذخیره تنظیمات هر کاربر برای پیشنهادات (تعداد مجاز، اولویت‌ها، فیلترها)
// کاربرد: مدیریت سقف استفاده و شخصی‌سازی پیشنهادات
// ------------------------------------------------------------
model UserSuggestionPreference {
  id                 String   @id @default(uuid())
  userId             String   @unique
  totalAllowed       Int      @default(100)       // تعداد کل پیشنهادات مجاز برای این کاربر
  resetPeriod        String   @default("monthly") // "daily" | "weekly" | "monthly" | "never"
  lastResetDate      DateTime @default(now())     // تاریخ آخرین بازنشانی
  preferredAdTypes   AdType[] @default([])        // اولویت‌های کاربر برای نوع آگهی (مثلاً فقط DigitalAd و SellerAd)
  preferredCategories String[] @default([])       // دسته‌بندی‌های مورد علاقه
  filterWeights      Json     @default("{}")      // وزن‌دهی به فیلترها مانند { "location": 0.3, "skills": 0.5, "category": 0.2 }
  isActive           Boolean  @default(true)

  user               User     @relation(fields: [userId], references: [id])
}

// ------------------------------------------------------------
// 3. جدول SuggestionDailyLimit (اختیاری اما مفید)
// هدف: ردیابی دقیق‌تر استفاده در بازه‌های زمانی کوتاه‌مدت (مثلاً سقف روزانه)
// کاربرد: مدیریت مصرف روزانه بدون نیاز به محاسبه از SuggestionView
// ------------------------------------------------------------
model SuggestionDailyLimit {
  id            String   @id @default(uuid())
  userId        String
  date          DateTime @default(now())   // تاریخ روز (بدون ساعت)
  countUsed     Int      @default(0)
  dailyLimit    Int      @default(20)      // سقف روزانه (می‌تواند از Preference خوانده شود)

  user          User     @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@index([userId, date])
}

// ------------------------------------------------------------
// 4. جدول AdSimilarityScore (بهینه‌سازی)
// هدف: ذخیره امتیاز شباهت بین هر جفت آگهی (از هر نوع) برای افزایش سرعت
// کاربرد: کاهش محاسبات تکراری در زمان تولید پیشنهادات
// ------------------------------------------------------------
model AdSimilarityScore {
  id              String   @id @default(uuid())
  adId1           String
  adType1         AdType
  adId2           String
  adType2         AdType
  similarityScore Float    // امتیاز بین ۰ تا ۱ (یا ۰ تا ۱۰۰)
  calculatedAt    DateTime @default(now())
  expiresAt       DateTime? // در صورت نیاز به انقضا

  @@unique([adId1, adType1, adId2, adType2])
  @@index([adId1, adType1])
  @@index([adId2, adType2])
}

// ------------------------------------------------------------
// 5. جدول CachedUserSuggestions (کش کردن نتایج)
// هدف: ذخیره لیست نهایی پیشنهادات هر کاربر به همراه زمان انقضا
// کاربرد: پاسخگویی سریع‌تر به درخواست‌های مکرر
// ------------------------------------------------------------
model CachedUserSuggestions {
  id              String   @id @default(uuid())
  userId          String   @unique
  suggestionIds   Json     // آرایه‌ای از شناسه‌های آگهی به همراه نوع: [{adId: "uuid", adType: "EmployerAd"}]
  generatedAt     DateTime @default(now())
  expiresAt       DateTime // مثلاً + ۵ دقیقه یا ۱ ساعت

  user            User     @relation(fields: [userId], references: [id])

  @@index([expiresAt])
}

// ========================
enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  HOLD
  REFUND
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELED
}

model Pricing {
  id          String   @id @default(uuid())
  key         String   @unique //  "base_ad_price", "special_price", "ladder_price", "renewal_price"
  value       Int // IRT
  description String?
  updatedAt   DateTime @updatedAt
}

model AdEnhancement {
  id     String @id @default(uuid())
  adId   String
  adType AdType

  // ویژه
  isSpecial        Boolean   @default(false)
  specialStartDate DateTime?
  specialEndDate   DateTime?

  // پله
  isStepped       Boolean   @default(false)
  stepScheduledAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Wallet {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  balance     Int @default(1000000)
  heldBalance Int @default(0)

  transactions Transaction[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  userProfiles UserProfile[]
}

model Transaction {
  id       String @id @default(uuid())
  walletId String
  wallet   Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  amount        Int
  type          TransactionType
  status        TransactionStatus @default(PENDING)
  description   String
  referenceId   String?
  paymentMethod PaymentMethod
  metadata      Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
